{
  "name": "signalk-container",
  "version": "0.2.1",
  "description": "Shared container runtime management (Podman/Docker) for Signal K plugins",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-plugin-configurator"
  ],
  "signalk": {
    "displayName": "Container Manager",
    "appIcon": "./icon.svg"
  },
  "signalk-plugin-enabled-by-default": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && webpack",
    "build:config": "webpack",
    "watch": "tsc --watch",
    "prettier": "prettier --write .",
    "lint": "eslint --fix",
    "format": "npm run prettier && npm run lint",
    "ci-lint": "eslint && prettier --check .",
    "test": "node --test 'dist/test/**/*.test.js'",
    "build:all": "npm run build && npm test",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dirkwa/signalk-container"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@signalk/server-api": "latest",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "babel-loader": "^10.1.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
